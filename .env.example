# ============================================
# MakeMyLook Multi-Agent AI Backend
# ============================================

# Server
PORT=3001
NODE_ENV=development

# NVIDIA NIM / Custom LLM Provider
OPENAI_API_KEY=your-nvidia-api-key-here
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_MODEL=qwen/qwen3.5-397b-a17b
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_ROUTER_MODEL=qwen/qwen3.5-397b-a17b

# Redis (Session Memory + Cache)
REDIS_URL=redis://localhost:6379

# ChromaDB (RAG Vector Store)
CHROMADB_URL=http://localhost:8000
CHROMADB_COLLECTION=mml_knowledge

# MakeMyLook API
MML_API_BASE_URL=https://api.makemylook.beauty
MML_WEBSITE_URL=https://makemylook.beauty
MML_API_TIMEOUT=10000
MML_API_MAX_RETRIES=3
MML_API_RATE_LIMIT=30

# Default Location (Bhubaneswar)
DEFAULT_LATITUDE=20.2961
DEFAULT_LONGITUDE=85.8245

# Logging
LOG_LEVEL=info

# Session
SESSION_TTL=86400
MAX_CONVERSATION_MESSAGES=20

# CORS
CORS_ORIGINS=http://localhost:3000,https://makemylook.beauty
